# ===========================================
# SavannaGuard Configuration
# ===========================================
# Copy this file to .env and customize before deploying.
#
# REQUIRED: You must set SECRET_KEY before running in production.
# All other values have sensible defaults.
# ===========================================

# --- Required ---

# Secret key for token encryption.
# IMPORTANT: Change this to a random string in production!
# Generate one with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-string

# Admin dashboard login password.
# Default: admin (change this in production!)
ADMIN_PASSWORD=admin

# Admin session lifetime in milliseconds (default: 12 hours)
# ADMIN_SESSION_TTL_MS=43200000

# --- Server ---

# HTTP port to listen on
# PORT=3000

# Host interface to bind (set 0.0.0.0 for Docker/container networking)
# HOST=0.0.0.0

# Database file path.
# Inside Docker, use /data/ prefix to persist data via volume.
# For local development, use ./data/savannaguard.db
# DB_PATH=/data/savannaguard.db

# Maximum accepted public challenge/token API body size in bytes (default: 128 KiB)
# BODY_LIMIT_BYTES=131072

# Log level: debug, info, warn, error
# LOG_LEVEL=info

# Trust X-Forwarded-* proxy headers for client IP/protocol.
# Enable only when SavannaGuard is behind a proxy you control.
# TRUST_PROXY=false

# Emit baseline security headers (default: true)
# SECURITY_HEADERS_ENABLED=true

# Allowed browser origins for the public challenge/token API.
# Default "*" is easiest for a separately hosted widget API.
# For production hardening, restrict to your site origin(s):
# CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
# CORS_ALLOWED_ORIGINS=*

# Require verdict tokens to be accepted only once (default: true)
# TOKEN_SINGLE_USE=true

# --- Federation (P2P Bot Intelligence) ---

# Enable to share bot signatures with other SavannaGuard instances
# FEDERATION_ENABLED=false

# Comma-separated list of peer instance URLs
# Example: FEDERATION_PEERS=https://sg1.example.com,https://sg2.example.com
# FEDERATION_PEERS=

# Pre-shared key for peer authentication (required if federation is enabled)
# Generate with: openssl rand -hex 32
# FEDERATION_PSK=

# How often to sync with active peers (milliseconds, default: 5 minutes)
# FEDERATION_SYNC_INTERVAL=300000

# How often to attempt recovery sync with offline peers (milliseconds, default: 30 minutes)
# FEDERATION_OFFLINE_SYNC_INTERVAL=1800000

# Consecutive failures before marking a peer offline (default: 3)
# FEDERATION_OFFLINE_THRESHOLD=3

# Max payload size for federation sync in bytes (default: 5 MB)
# FEDERATION_MAX_PAYLOAD_BYTES=5242880

# Request timeout for peer communication in milliseconds (default: 30 seconds)
# FEDERATION_REQUEST_TIMEOUT_MS=30000

# Max retry attempts for failed peer requests (default: 3)
# FEDERATION_MAX_RETRIES=3

# Base delay between retries in milliseconds (default: 5 seconds)
# FEDERATION_BASE_RETRY_DELAY_MS=5000

# Maximum delay between retries in milliseconds (default: 60 seconds)
# FEDERATION_MAX_RETRY_DELAY_MS=60000

# Allow federation peers on private/local networks (Docker, VPN, internal).
# SECURITY: when true, private IPs are allowed and non-private hosts must still use HTTPS.
# FEDERATION_ALLOW_PRIVATE_PEERS=false

# --- Adaptive ML ---

# Minimum human samples before adaptive model starts influencing score (default: 10)
# ADAPTIVE_MIN_SAMPLES=10

# --- Passive Protection ---

# Master switch for passive protection (default: true)
# PASSIVE_PROTECTION_ENABLED=true

# Block known datacenter/hosting IP ranges outright (default: false)
# PASSIVE_PROTECTION_BLOCK_DC=false

# Per-minute challenge limit for datacenter IPs when not blocked (default: 3)
# PASSIVE_PROTECTION_DC_RATE_LIMIT=3

# Extra custom CIDR ranges to treat as datacenter/blocked candidates (comma-separated)
# PASSIVE_PROTECTION_CUSTOM_RANGES=
